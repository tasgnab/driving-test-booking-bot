# Copy this file to .env and fill in your credentials
# DO NOT commit .env to version control

USERNAME=your_username_here
PASSWORD=your_password_here
PHONE=your_phone_number
LICENSE_NUMBER=your_license_number

# Test location (option value from dropdown)
# To find your location code, run: npm run codegen
LOCATION=37

# Optional: Multiple locations to check (comma-separated)
# LOCATIONS=37,38,39

# Optional: Preferred booking details
PREFERRED_DAYS=Mon,Tue,Wed
PREFERRED_TIMES=9:15 am,10:00 am,11:00 am
MIN_TIME=9:00 am
MAX_TIME=5:00 pm
